<div class="kg-board">
{{#unless active}}
  <p class="kg-empty">{{localize "KNUCKLES.board.noGame"}}</p>
{{else}}

  {{#if hasPot}}
    <div class="kg-pot">
      <span class="kg-muted">{{localize "KNUCKLES.board.pot"}}</span>
      <span class="kg-coin kg-sun">{{pool.sun}} {{localize "KNUCKLES.coin.sun"}}</span>
      <span class="kg-coin kg-gold">{{pool.gold}} {{localize "KNUCKLES.coin.gold"}}</span>
      <span class="kg-coin kg-silver">{{pool.silver}} {{localize "KNUCKLES.coin.silver"}}</span>
      <span class="kg-coin kg-copper">{{pool.copper}} {{localize "KNUCKLES.coin.copper"}}</span>
    </div>
  {{/if}}

  {{#if finalRound.active}}
    <div class="kg-banner kg-final"><i class="fa-solid fa-flag" aria-hidden="true"></i> {{localize "KNUCKLES.board.finalRound"}}</div>
  {{/if}}
  {{#if finished}}
    <div class="kg-banner kg-win">
      {{#if tie}}{{localize "KNUCKLES.board.tie"}}{{else}}<i class="fa-solid fa-trophy" aria-hidden="true"></i> {{localize "KNUCKLES.board.winner"}}: {{winner.name}}{{/if}}
    </div>
  {{/if}}

  <div class="kg-scoreboard">
    {{#each players}}
      <div class="kg-pcard{{#if isCurrent}} is-current{{/if}}{{#if isWinner}} is-winner{{/if}}">
        <div class="kg-pname">{{name}}{{#if isCurrent}} · {{localize "KNUCKLES.board.turn"}}{{/if}}</div>
        <div class="kg-ptotal">{{total}}</div>
        <div class="kg-hero">
          {{#if showHero}}{{#each heroPips}}<span class="kg-pip-hp{{#if on}} on{{/if}}"></span>{{/each}}{{else}}<span class="kg-muted">{{localize "KNUCKLES.board.noHero"}}</span>{{/if}}
        </div>
      </div>
    {{/each}}
    <div class="kg-target">
      <div class="kg-muted">{{localize "KNUCKLES.board.target"}}</div>
      <div class="kg-tval">{{targetScore}}</div>
    </div>
  </div>

  {{#unless finished}}
    <div class="kg-turn">
      <span class="kg-muted">{{localize "KNUCKLES.board.turnTotal"}}</span>
      <span class="kg-turnscore">{{turnScore}}</span>
    </div>

    {{#if isBustPhase}}
      <div class="kg-banner kg-bust"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> {{localize "KNUCKLES.board.bust"}}</div>
    {{/if}}

    <div class="kg-tray">
      {{#each dice}}
        <div class="kg-slot">
          <span class="kg-idx{{#if named}} kg-named{{/if}}"{{#if flavor}} title="{{flavor}}"{{/if}}>{{label}}</span>
          <div class="kg-die{{#if kept}} is-kept{{/if}}{{#if selected}} is-selected{{/if}}{{#if reroll}} is-reroll{{/if}}{{#if blank}} is-blank{{/if}}{{#if isWild}} is-wild{{/if}}"
               data-die-id="{{id}}" data-value="{{value}}"{{#if inPlay}} data-action="toggleDie"{{/if}}>
            {{#if isWild}}<i class="fa-solid fa-wand-sparkles kg-wild" aria-hidden="true"></i>{{else}}<span class="kg-die-num">{{value}}</span><span class="kg-pips">{{#each (kgRange 9)}}<span class="kg-pip"></span>{{/each}}</span>{{/if}}
          </div>
          {{#if canEdit}}
            <button type="button" class="kg-edit{{#if editing}} on{{/if}}" data-action="editDie" data-die-id="{{id}}" aria-label="{{localize 'KNUCKLES.board.editDie'}}"><i class="fa-solid fa-pen" aria-hidden="true"></i></button>
          {{/if}}
          {{#if editing}}
            <div class="kg-valpop">
              <div class="kg-valpop-arr"></div>
              <div class="kg-valpop-h">{{localize "KNUCKLES.board.pickFace"}}</div>
              <div class="kg-valopts">
                {{#each @root.faces}}
                  <button type="button" class="kg-valopt" data-action="setDieValue" data-die-id="{{../id}}" data-value="{{this}}" aria-label="{{this}}">
                    <span class="kg-die kg-mini" data-value="{{this}}"><span class="kg-die-num">{{this}}</span><span class="kg-pips">{{#each (kgRange 9)}}<span class="kg-pip"></span>{{/each}}</span></span>
                  </button>
                {{/each}}
              </div>
              <button type="button" class="kg-valopt-wild" data-action="setDieValue" data-die-id="{{id}}" data-value="wild"><i class="fa-solid fa-wand-sparkles" aria-hidden="true"></i> {{localize "KNUCKLES.board.wild"}}</button>
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>

    <p class="kg-hint">
      {{#if heroMode}}{{localize "KNUCKLES.board.heroHint"}}
      {{else if selectionValid}}{{localize "KNUCKLES.board.selected"}}: {{selectionPoints}}{{/if}}
    </p>

    <div class="kg-controls">
      {{#if canRoll}}<button type="button" data-action="roll"><i class="fa-solid fa-dice" aria-hidden="true"></i> {{localize "KNUCKLES.board.roll"}}</button>{{/if}}
      {{#if heroMode}}
        <button type="button" class="kg-hero-btn" data-action="heroConfirm"{{#unless canHeroConfirm}} disabled{{/unless}}><i class="fa-solid fa-rotate" aria-hidden="true"></i> {{localize "KNUCKLES.board.confirmReroll"}} ({{rerollCount}})</button>
        <button type="button" data-action="heroCancel">{{localize "KNUCKLES.board.cancel"}}</button>
      {{else}}
        {{#if canKeepRoll}}<button type="button" class="primary" data-action="keepRoll">{{localize "KNUCKLES.board.keepRoll"}}</button>{{/if}}
        {{#if canKeepBank}}<button type="button" data-action="keepBank">{{localize "KNUCKLES.board.keepBank"}}</button>{{/if}}
        {{#if canTakeBust}}<button type="button" data-action="takeBust">{{localize "KNUCKLES.board.takeBust"}}</button>{{/if}}
        {{#if canHeroOpen}}<button type="button" class="kg-hero-btn" data-action="heroOpen"><i class="fa-solid fa-star" aria-hidden="true"></i> {{localize "KNUCKLES.board.useHero"}} ({{heroPoints}})</button>{{/if}}
      {{/if}}
    </div>
  {{/unless}}

  {{#if log.length}}
    <div class="kg-log">
      {{#each log}}<div class="kg-log-line">{{this}}</div>{{/each}}
    </div>
  {{/if}}

  {{#if isGM}}<div class="kg-foot">
    {{#if canOpenDice}}<button type="button" data-action="openDice"><i class="fa-solid fa-dice-d6" aria-hidden="true"></i> {{localize "KNUCKLES.board.changeDice"}}</button>{{/if}}
    <button type="button" class="kg-end" data-action="endGame"><i class="fa-solid fa-flag-checkered" aria-hidden="true"></i> {{localize "KNUCKLES.board.endGame"}}</button>
    <button type="button" data-action="newGame"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i> {{localize "KNUCKLES.board.newGame"}}</button>
  </div>{{/if}}
{{/unless}}
</div>
