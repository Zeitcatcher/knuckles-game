<div class="kg-setup">
  <div class="kg-prow kg-prow-head">
    <span class="kg-muted">{{localize "KNUCKLES.setup.character"}}</span>
    <span></span>
  </div>
  <div class="kg-players">
    {{#each players}}
      <div class="kg-pblock" data-player-block data-index="{{@index}}">
        <div class="kg-prow">
          <div class="kg-combo" data-combo>
            <input type="text" name="name" value="{{name}}" placeholder="{{localize 'KNUCKLES.setup.searchChar'}}" autocomplete="off" role="combobox" aria-autocomplete="list" aria-expanded="false" />
            <input type="hidden" name="actorUuid" value="{{actorUuid}}" />
            <input type="hidden" name="tokenUuid" value="{{tokenUuid}}" />
            <div class="kg-combo-list" role="listbox" hidden>
              {{#each ../actors}}
                <button type="button" class="kg-combo-item" role="option" data-uuid="{{uuid}}" data-name="{{name}}">{{name}}</button>
              {{/each}}
            </div>
          </div>
          {{#if tokenUuid}}<span class="kg-token-badge" title="{{localize 'KNUCKLES.setup.tokenTitle'}}"><i class="fa-solid fa-location-crosshairs" aria-hidden="true"></i> {{localize 'KNUCKLES.setup.tokenBadge'}}</span>{{/if}}
          <button type="button" class="kg-icon" data-action="removePlayer" data-index="{{@index}}" aria-label="{{localize 'KNUCKLES.setup.remove'}}"><i class="fa-solid fa-trash" aria-hidden="true"></i></button>
        </div>
        <div class="kg-bets">
          <span class="kg-bet-label">{{localize "KNUCKLES.setup.bet"}}</span>
          <label class="kg-bet"><span>{{localize "KNUCKLES.coin.sun"}}</span><input type="number" name="sun" value="{{bet.sun}}" min="0" step="1" /></label>
          <label class="kg-bet"><span>{{localize "KNUCKLES.coin.gold"}}</span><input type="number" name="gold" value="{{bet.gold}}" min="0" step="1" /></label>
          <label class="kg-bet"><span>{{localize "KNUCKLES.coin.silver"}}</span><input type="number" name="silver" value="{{bet.silver}}" min="0" step="1" /></label>
          <label class="kg-bet"><span>{{localize "KNUCKLES.coin.copper"}}</span><input type="number" name="copper" value="{{bet.copper}}" min="0" step="1" /></label>
        </div>
      </div>
    {{/each}}
  </div>

  <div class="kg-setup-actions">
    <button type="button" data-action="addPlayer"><i class="fa-solid fa-plus" aria-hidden="true"></i> {{localize "KNUCKLES.setup.addPlayer"}}</button>
    <button type="button" data-action="addTokens"><i class="fa-solid fa-location-crosshairs" aria-hidden="true"></i> {{localize "KNUCKLES.setup.addTokens"}}</button>
  </div>

  <div class="kg-target-row">
    <label>{{localize "KNUCKLES.setup.playTo"}}</label>
    <input type="number" name="targetScore" value="{{defaultTarget}}" step="50" min="100" />
  </div>

  <footer class="kg-setup-foot">
    <button type="submit" class="primary"><i class="fa-solid fa-play" aria-hidden="true"></i> {{localize "KNUCKLES.setup.start"}}</button>
  </footer>
</div>
