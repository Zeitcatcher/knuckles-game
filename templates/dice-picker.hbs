<div class="kg-dice">
{{#unless active}}
  <p class="kg-empty">{{localize "KNUCKLES.dice.none"}}</p>
{{else}}
  {{#if choosing}}<div class="kg-muted" style="margin-bottom:10px">{{localize "KNUCKLES.dice.hint"}}</div>{{/if}}
  <div class="kg-dchars">
  {{#each players}}
    <div class="kg-dchar">
      <div class="kg-pname">{{name}}{{#if ready}} <i class="fa-solid fa-check" aria-hidden="true" style="color:var(--kg-win)"></i>{{/if}}</div>
      {{#if ownsNone}}<div class="kg-buyhint"><i class="fa-solid fa-cart-shopping" aria-hidden="true"></i> {{localize "KNUCKLES.dice.buyHint"}}</div>{{/if}}
      <div class="kg-dslots">
        {{#each slots}}
          <label class="kg-dslot">
            <span class="kg-idx">#{{n}}</span>
            <select data-die-slot data-player-id="{{../id}}" data-slot="{{slot}}">
              {{#each options}}<option value="{{id}}"{{#if selected}} selected{{/if}}{{#if disabled}} disabled{{/if}} title="{{flavor}}">{{#if check}}✓ {{/if}}{{label}}</option>{{/each}}
            </select>
            {{#if ../phys}}
              <span class="kg-owned{{#if owned}} is-owned{{/if}}" title="{{#if owned}}{{localize 'KNUCKLES.dice.inInv'}}{{else}}{{localize 'KNUCKLES.dice.notInInv'}}{{/if}}">
                <i class="fa-solid {{#if owned}}fa-check{{else}}fa-minus{{/if}}" aria-hidden="true"></i>
              </span>
            {{/if}}
          </label>
        {{/each}}
      </div>
    </div>
  {{/each}}
  </div>
  <footer class="kg-dice-foot">
    {{#if choosing}}
      {{#if isGM}}
        <button type="button" class="primary" data-action="startPlay"><i class="fa-solid fa-play" aria-hidden="true"></i> {{localize "KNUCKLES.dice.start"}}</button>
        <button type="button" class="kg-end" data-action="endGame"><i class="fa-solid fa-flag-checkered" aria-hidden="true"></i> {{localize "KNUCKLES.board.endGame"}}</button>
      {{else}}
        <button type="button" class="primary" data-action="ready"><i class="fa-solid fa-check" aria-hidden="true"></i> {{localize "KNUCKLES.dice.ready"}}</button>
      {{/if}}
    {{else}}
      <button type="button" data-action="close">{{localize "KNUCKLES.dice.close"}}</button>
    {{/if}}
  </footer>
{{/unless}}
</div>
