<div class="kg-dice">
{{#unless active}}
  <p class="kg-empty">{{localize "KNUCKLES.dice.none"}}</p>
{{else}}
  {{#if choosing}}<div class="kg-muted" style="margin-bottom:10px">{{localize "KNUCKLES.dice.hint"}}</div>{{/if}}
  <div class="kg-dchars">
  {{#each players}}
    <div class="kg-dchar">
      <div class="kg-dchar-head">
        <span class="kg-pname">{{name}}{{#if ready}} <i class="fa-solid fa-check" aria-hidden="true" style="color:var(--kg-win)"></i>{{/if}}</span>
        {{#if tally}}<span class="kg-tally{{#unless tally.ok}} is-short{{/unless}}"><i class="fa-solid {{#if tally.ok}}fa-check{{else}}fa-triangle-exclamation{{/if}}" aria-hidden="true"></i> {{tally.have}} / 6</span>{{/if}}
      </div>
      {{#if tally}}<div class="kg-buyhint">{{#if buyHint}}<i class="fa-solid fa-cart-shopping" aria-hidden="true"></i> {{buyHint}}{{/if}}</div>{{/if}}
      {{#if stockNote}}<div class="kg-stocknote"><i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i> {{stockNote}}</div>{{/if}}
      <div class="kg-dslots">
        {{#each slots}}
          <label class="kg-dslot">
            <span class="kg-idx">#{{n}}</span>
            <select data-die-slot data-player-id="{{../id}}" data-slot="{{slot}}">
              {{#each options}}<option value="{{id}}"{{#if selected}} selected{{/if}}{{#if disabled}} disabled{{/if}} title="{{flavor}}">{{label}}</option>{{/each}}
            </select>
            {{#if mark}}<span class="kg-owned {{mark.cls}}" title="{{mark.title}}"><i class="fa-solid {{mark.icon}}" aria-hidden="true"></i></span>{{/if}}
          </label>
        {{/each}}
      </div>
    </div>
  {{/each}}
  </div>
  <footer class="kg-dice-foot">
    {{#if choosing}}
      {{#if isGM}}
        <button type="button" class="primary" data-action="startPlay"><i class="fa-solid fa-play" aria-hidden="true"></i> {{localize "KNUCKLES.dice.start"}}</button>
        <button type="button" class="kg-end" data-action="endGame"><i class="fa-solid fa-flag-checkered" aria-hidden="true"></i> {{localize "KNUCKLES.board.endGame"}}</button>
      {{else}}
        <button type="button" class="primary" data-action="ready"><i class="fa-solid fa-check" aria-hidden="true"></i> {{localize "KNUCKLES.dice.ready"}}</button>
      {{/if}}
    {{else}}
      <button type="button" data-action="close">{{localize "KNUCKLES.dice.close"}}</button>
    {{/if}}
  </footer>
{{/unless}}
</div>
